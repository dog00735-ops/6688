OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

MONITOR_NAME=台灣輿情監控
POLITICAL_INTEL_DB=political_intel.db
MAX_ITEMS_PER_RUN=10
DAILY_REPORT_LIMIT=12
HTTP_TIMEOUT=20
SSL_VERIFY=true
SSL_CA_BUNDLE=
DEDUPE_HOURS=24
TELEGRAM_PREVIEW=true
ENABLE_TELEGRAM=true
MAX_FEED_WORKERS=4

MONITOR_KEYWORDS=總統,民調,聲量,輿情,選舉,罷免,國會,政策,兩岸,外交,爭議,起訴
PRIORITY_KEYWORDS=總統,民調,聲量,選舉,罷免,國安,兩岸,外交,起訴
POSITIVE_HINTS=宣布,支持,主打,推出,領先,看好,回升
NEGATIVE_HINTS=質疑,爭議,弊案,失言,起訴,檢調,下滑,暴跌

# 可選：若你要自訂對象/主題判斷，可填 JSON 字串
# ENTITY_HINTS_JSON={"民進黨":["民進黨","賴清德"],"國民黨":["國民黨","侯友宜"]}
# TOPIC_HINTS_JSON={"民調聲量":["民調","聲量"],"爭議事件":["爭議","起訴"]}
